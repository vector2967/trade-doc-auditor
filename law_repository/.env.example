# 복사해서 .env 로 사용 (실제 .env 는 gitignore). 값 하드코딩 금지.

# --- Postgres (시간버전 원장) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trade_doc
POSTGRES_USER=trade
POSTGRES_PASSWORD=change_me

# --- Qdrant (현행 인덱스) ---
QDRANT_URL=http://localhost:6333
# Qdrant Cloud 사용 시에만 (로컬 도커는 비움)
QDRANT_API_KEY=

# 관리형 PG(Neon 등) 사용 시 require, 로컬 도커는 비움
POSTGRES_SSLMODE=

# --- Neo4j (그래프) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me

# --- 법제처 국가법령정보 공동활용 API (조문 fetch) ---
LAW_API_OC=alfinekey

# --- 공공데이터포털 (세관장확인대상물품 등, Phase 4) ---
DATA_GO_KR_SERVICE_KEY=your_service_key_here
