# 클라우드(서버리스 조합) 접속 템플릿 — 경로 2
# 로컬에서 클라우드로 데이터를 적재할 때 이 값들로 .env 를 교체한다.
# HF Spaces / GitHub Actions 에는 파일이 아니라 Secrets 로 같은 키를 등록한다.

# --- Neon (서버리스 Postgres) — 콘솔의 Connection Details 에서 ---
POSTGRES_HOST=ep-xxxx-xxxx.ap-southeast-1.aws.neon.tech
POSTGRES_PORT=5432
POSTGRES_DB=trade_doc
POSTGRES_USER=trade_doc_owner
POSTGRES_PASSWORD=<neon 비밀번호>
POSTGRES_SSLMODE=require

# --- Qdrant Cloud (free cluster) — 콘솔의 Cluster URL + API Key ---
QDRANT_URL=https://xxxx.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=<qdrant api key>

# --- Neo4j AuraDB Free — 인스턴스 생성 시 받은 접속정보 ---
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=<aura 비밀번호>

# --- 외부 API (기존과 동일) ---
LAW_API_OC=alfinekey
DATA_GO_KR_SERVICE_KEY=<공공데이터포털 키>

# --- 웹 데모 접근 보호 (HF Spaces 환경변수로) ---
DEMO_TOKEN=<팀원과 공유할 임의 문자열>
